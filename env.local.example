# Rename this file to .env.local and fill in your values

# ─── Auth0 ──────────────────────────────────────────────────────
# Get from: manage.auth0.com → Applications → your app → Settings
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=                          # Generate: openssl rand -hex 32
APP_BASE_URL=http://localhost:3000     # Change to your Vercel URL in production

# ─── Auth0 M2M (optional `x-agent-token` on agent routes) ───────
# JWT path: same API Identifier as in Auth0 → APIs → your API (e.g. https://openstep-api)
AUTH0_AUDIENCE=https://openstep-api
# From your Machine-to-Machine app (client credentials → access token)
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
# Legacy HMAC token (openssl rand -hex 32); used if token is not a JWT
AUTH0_M2M_SECRET=

# ─── Supabase ───────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose to client

# ─── Perplexity (Sage agent) ────────────────────────────────────
# Get from: perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key

# ─── E2B (Forge terminal sandbox) ───────────────────────────────
# Get from: e2b.dev/dashboard
E2B_API_KEY=your-e2b-key

# ─── GitHub ─────────────────────────────────────────────────────
# Optional shared PAT — raises rate limits for all users’ server-side calls.
# Scout/Oracle still scan the GitHub username each user enters on the dashboard (not the token owner).
GITHUB_TOKEN=ghp_your-personal-access-token

# ─── GitHub Webhooks (Guardian agent) ───────────────────────────
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Database: after creating the Supabase project, run supabase/schema.sql in the SQL Editor.
